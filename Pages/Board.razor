@page "/board"
@layout BoardLayout
@inject GameEngineService GameEngine
@inject GameHostVoiceService HostVoice
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tabuleiro — Não Comemore Antes do Fim</PageTitle>

@if (!GameEngine.IsGameStarted)
{
    <div class="board-empty">
        <p>Nenhuma partida em andamento.</p>
        <a class="btn btn-primary btn-lg" href="/">Voltar à configuração</a>
    </div>
}
else if (GameEngine.IsGameEnded)
{
    <div class="game-end-screen game-end-celebrate">
        <h1>Fim de Jogo</h1>
        <p class="game-end-reason">@GetEndGameMessage()</p>
        @{
            var rankedPlayers = GameEngine.GetRankedPlayers().ToList();
            var champion = GameEngine.GetWinnerPlayer() ?? GameEngine.GetChocolateLeader();
        }
        @if (champion is not null && (champion.Points > 0 || champion.Chocolates > 0))
        {
            <p class="game-end-champion">Quem mais pontuou: <strong>@champion.Name</strong> (⭐ @champion.Points pts · 🍫 @champion.Chocolates)</p>
        }
        @if (rankedPlayers.Count > 0)
        {
            <div class="podium">
                @if (rankedPlayers.Count > 1)
                {
                    <div class="podium-slot podium-slot--2">
                        <span class="podium-medal">🥈</span>
                        <span class="podium-name">@rankedPlayers[1].Name</span>
                        <span class="podium-fun-title">@GetFunTitle(rankedPlayers[1], 1)</span>
                        <span class="podium-score">⭐ @rankedPlayers[1].Points · 🍫 @rankedPlayers[1].Chocolates</span>
                    </div>
                }
                <div class="podium-slot podium-slot--1">
                    <span class="podium-medal">🥇</span>
                    <span class="podium-name">@rankedPlayers[0].Name</span>
                    <span class="podium-fun-title">@GetFunTitle(rankedPlayers[0], 0)</span>
                    <span class="podium-score">⭐ @rankedPlayers[0].Points · 🍫 @rankedPlayers[0].Chocolates</span>
                </div>
                @if (rankedPlayers.Count > 2)
                {
                    <div class="podium-slot podium-slot--3">
                        <span class="podium-medal">🥉</span>
                        <span class="podium-name">@rankedPlayers[2].Name</span>
                        <span class="podium-fun-title">@GetFunTitle(rankedPlayers[2], 2)</span>
                        <span class="podium-score">⭐ @rankedPlayers[2].Points · 🍫 @rankedPlayers[2].Chocolates</span>
                    </div>
                }
            </div>
        }
        @if (GameEngine.EndReason == GameEndReason.QuestionsExhausted)
        {
            <p class="game-end-note">Se sobrou chocolate na caixa, divida entre todos os jogadores.</p>
        }
        <ol class="final-ranking">
            @foreach (var (player, index) in GameEngine.GetRankedPlayers().Select((p, i) => (p, i)))
            {
                <li class="final-ranking-item @(index == 0 ? "winner" : "")">
                    <span class="rank">@(index + 1)º</span>
                    <span class="name">@player.Name</span>
                    <span class="score">
                        <span class="points-count" title="Pontos">⭐ @player.Points pts</span>
                        <span class="chocolate-count">🍫 @player.Chocolates</span>
                    </span>
                </li>
            }
        </ol>
        <button type="button" class="btn btn-primary btn-lg" @onclick="GoHome">
            Nova partida
        </button>
    </div>
}
else
{
    <div class="board-page">
        <div class="game-status-bar">
            <span class="game-clock" role="timer" aria-live="polite">⏱ @FormatGameClock()</span>
            <span>Perguntas: @GameEngine.QuestionsRemaining</span>
            <span>Ações: @GameEngine.ActionCardsRemaining</span>
            <div class="host-voice-controls" title="Apresentador virtual na TV">
                <label class="host-voice-toggle">
                    <input type="checkbox" @bind="hostVoiceEnabled" @bind:after="SyncHostVoiceSettings" />
                    <span>🎙 Apresentador</span>
                </label>
                <label class="host-voice-toggle" title="Ler o texto da pergunta em voz alta">
                    <input type="checkbox" @bind="hostReadQuestions" @bind:after="SyncHostVoiceSettings" disabled="@(!hostVoiceEnabled)" />
                    <span>Ler perguntas</span>
                </label>
                @if (hostVoiceEnabled && GameEngine.CurrentCard is not null && GameEngine.CardRevealed)
                {
                    <button type="button" class="btn btn-sm btn-outline-light host-repeat-btn" @onclick="RepeatHostSpeech">
                        🔊 Repetir
                    </button>
                }
            </div>
            <button type="button" class="btn btn-sm btn-outline-light rules-toggle" @onclick="ToggleRules">
                @(showRules ? "Ocultar regras" : "Regras")
            </button>
        </div>
        @if (showRules)
        {
            <GameRulesPanel />
        }
    <div class="game-board">
        <aside class="scoreboard">
            <h2>Placar</h2>
            <ul class="scoreboard-list">
                @foreach (var player in GameEngine.Players)
                {
                    var isCurrent = GameEngine.CurrentPlayer?.Id == player.Id;
                    <li class="scoreboard-item @(isCurrent ? "current-turn" : "") @(scoreBumpIds.Contains(player.Id) ? "score-bump" : "")">
                        <span class="player-name">@player.Name</span>
                        <span class="player-scores">
                            <span class="points-count" title="Pontos">⭐ @player.Points pts</span>
                            <span class="chocolate-count" title="Chocolates">🍫 @player.Chocolates</span>
                        </span>
                        @if (isCurrent)
                        {
                            <span class="turn-badge">Sua vez</span>
                        }
                    </li>
                }
            </ul>
        </aside>

        <main class="board-center">
            @if (GameEngine.CurrentPlayer is not null)
            {
                <p class="current-player-banner spotlight-pulse">
                    Vez de: <strong>@GameEngine.CurrentPlayer.Name</strong>
                </p>
            }

            @if (GameEngine.CurrentCard is null)
            {
                <button class="btn btn-draw-card @(drawPulse ? "is-drawing" : "")"
                        type="button"
                        @onclick="DrawCard"
                        disabled="@(isDrawing || GameEngine.QuestionsRemaining == 0)">
                    Sortear Carta
                </button>
                @if (GameEngine.QuestionsRemaining == 0)
                {
                    <p class="text-muted mt-2">As cartas de pergunta acabaram.</p>
                }
            }
            else
            {
                <div class="board-play-column">
                    @if (ShowAnswerTimer)
                    {
                        <div class="answer-timer @(answerSecondsRemaining <= 10 ? "answer-timer-urgent" : "")" role="timer" aria-live="polite">
                            <span class="answer-timer-label">Mostrar resposta em</span>
                            <span class="answer-timer-value">@FormatTimer(answerSecondsRemaining)</span>
                        </div>
                    }

                    <div class="card-scene @(cardDrawnPop ? "card-scene--entered" : "")">
                        <div class="card-flip @(GameEngine.CardRevealed ? "is-flipped" : "") @(cardRevealFlash ? "card-reveal-flash" : "")">
                            <div class="card-face card-back" @onclick="RevealCard">
                                <div class="card-back-inner">
                                    <p class="card-back-title">NÃO</p>
                                    <p class="card-back-title">COMEMORE</p>
                                    <p class="card-back-title">ANTES DO</p>
                                    <p class="card-back-title">FIM</p>
                                    <small class="card-back-hint">Toque para virar</small>
                                </div>
                            </div>
                            <div class="card-face card-front @GetCardTypeClass(GameEngine.CurrentCard)">
                                <span class="card-number">@GameEngine.CurrentCard.Id</span>
                                <div class="card-front-content">
                                    <span class="card-type-label">@GetCardTypeLabel(GameEngine.CurrentCard)</span>
                                    <p class="card-text">@GameEngine.CurrentCard.Text</p>

                                    @if (GameEngineService.IsQuestionCard(GameEngine.CurrentCard))
                                    {
                                        @if (!GameEngine.CardRevealed)
                                        {
                                            <p class="card-number-hint">Diga em voz alta: Pergunta nº @GameEngine.CurrentCard.Id</p>
                                        }

                                        @if (GameEngine.CurrentCard.HasMultipleChoice && GameEngine.CardRevealed)
                                        {
                                            <div class="mc-options">
                                                @foreach (var opt in new[] { 'A', 'B', 'C' })
                                                {
                                                    var label = opt switch { 'A' => GameEngine.CurrentCard.OptionA, 'B' => GameEngine.CurrentCard.OptionB, _ => GameEngine.CurrentCard.OptionC };
                                                    var isSelected = GameEngine.SelectedOption == opt;
                                                    var isCorrect  = opt == GameEngine.CurrentCard.CorrectOption;
                                                    var answered   = GameEngine.EffectApplied;
                                                    var css = answered
                                                        ? (isCorrect ? "mc-btn mc-btn-correct" : (isSelected ? "mc-btn mc-btn-wrong" : "mc-btn mc-btn-neutral"))
                                                        : "mc-btn";
                                                    <button type="button"
                                                            class="@css"
                                                            disabled="@answered"
                                                            @onclick="() => SelectOption(opt)">
                                                        <span class="mc-letter">@opt</span>
                                                        <span class="mc-text">@label</span>
                                                    </button>
                                                }
                                            </div>
                                            @if (GameEngine.EffectApplied && !string.IsNullOrEmpty(GameEngine.CurrentCard.Answer))
                                            {
                                                <p class="card-answer"><strong>Resposta completa:</strong> @GameEngine.CurrentCard.Answer</p>
                                            }
                                        }
                                        else if (!GameEngine.CurrentCard.HasMultipleChoice)
                                        {
                                            @if (!GameEngine.ShowAnswer)
                                            {
                                                <button type="button" class="btn btn-primary btn-sm" @onclick="RevealAnswer">
                                                    Ver Resposta
                                                </button>
                                            }
                                            else if (!string.IsNullOrEmpty(GameEngine.CurrentCard.Answer))
                                            {
                                                <p class="card-answer"><strong>Resposta:</strong> @GameEngine.CurrentCard.Answer</p>
                                            }
                                        }
                                    }

                                    @if (GameEngine.EffectApplied && !ShowGradingPanel && !ShowGradingResult && !ShowSocialChallenge)
                                    {
                                        @if (!GameEngineService.IsQuestionCard(GameEngine.CurrentCard) || !GameEngine.CurrentCard.HasMultipleChoice)
                                        {
                                            <p class="effect-applied-msg">Efeito aplicado!</p>
                                        }
                                    }
                                </div>
                                <span class="card-crown" aria-hidden="true">♛</span>
                            </div>
                        </div>
                    </div>

                    @if (ShowGradingPanel)
                    {
                        <div class="card-actions-panel question-grading">
                            <p class="grading-label">Conferiu com o gabarito?</p>
                            <div class="grading-buttons">
                                <button type="button"
                                        class="btn btn-grade-correct"
                                        @onclick="() => RecordAnswer(correct: true)">
                                    ✓ Acertou (+@GameRules.PointsPerCorrectAnswer pts · +@GameRules.ChocolatesPerCorrectAnswer 🍫)
                                </button>
                                <button type="button"
                                        class="btn btn-grade-wrong"
                                        @onclick="() => RecordAnswer(correct: false)">
                                    ✗ Errou
                                </button>
                            </div>
                        </div>
                    }
                    else if (ShowGradingResult)
                    {
                        <div class="card-actions-panel">
                            <p class="grading-result @(GameEngine.LastQuestionWasCorrect!.Value ? "correct" : "wrong")">
                                @(GameEngine.LastQuestionWasCorrect.Value
                                    ? $"Acertou! +{GameRules.PointsPerCorrectAnswer} pontos e +{GameRules.ChocolatesPerCorrectAnswer} chocolate."
                                    : (GameEngine.CurrentCard?.HasMultipleChoice == true
                                        ? $"Errou! A resposta correta era a opção {GameEngine.CurrentCard.CorrectOption}."
                                        : "Errou — sem pontos nem chocolate desta pergunta."))
                            </p>
                        </div>
                    }
                    else if (NeedsDonationTargets)
                    {
                        <div class="card-actions-panel target-selection">
                            <label class="form-label" for="donorPlayer">Quem doa os chocolates:</label>
                            <select id="donorPlayer" class="form-select mb-2" @bind="donorPlayerIdString">
                                <option value="">— Selecione —</option>
                                @foreach (var player in OtherPlayers)
                                {
                                    <option value="@player.Id.ToString()">@player.Name (🍫@player.Chocolates)</option>
                                }
                            </select>
                            <label class="form-label" for="recipientPlayer">Quem recebe:</label>
                            <select id="recipientPlayer" class="form-select" @bind="recipientPlayerIdString">
                                <option value="">— Selecione —</option>
                                @foreach (var player in OtherPlayers)
                                {
                                    <option value="@player.Id.ToString()">@player.Name</option>
                                }
                            </select>
                            <button type="button"
                                    class="btn btn-warning mt-2 w-100"
                                    @onclick="ApplyDonationEffect"
                                    disabled="@(!CanApplyDonation)">
                                Aplicar doação
                            </button>
                        </div>
                    }
                    else if (NeedsTargetSelection)
                    {
                        <div class="card-actions-panel target-selection">
                            <label class="form-label" for="targetPlayer">Escolha um jogador:</label>
                            <select id="targetPlayer" class="form-select" @bind="selectedTargetIdString">
                                <option value="">— Selecione —</option>
                                @foreach (var player in OtherPlayers)
                                {
                                    <option value="@player.Id.ToString()">@player.Name (🍫@player.Chocolates)</option>
                                }
                            </select>
                            <button type="button"
                                    class="btn btn-warning mt-2 w-100"
                                    @onclick="ApplyTargetEffect"
                                    disabled="@(!CanApplyTarget)">
                                Aplicar efeito
                            </button>
                        </div>
                    }
                    else if (ShowSocialChallenge)
                    {
                        <div class="social-challenge-stage">
                            <p class="social-challenge-kicker">🎭 Desafio na roda</p>
                            <p class="social-challenge-player">@GameEngine.CurrentPlayer?.Name</p>
                            <p class="social-challenge-text">@GameEngine.CurrentCard?.Text</p>
                            <button type="button" class="btn btn-social-done" @onclick="ConfirmSocialChallenge">
                                🎉 Desafio feito!
                            </button>
                        </div>
                    }

                    <button type="button"
                            class="btn btn-secondary btn-lg btn-pass-turn"
                            @onclick="PassTurn"
                            disabled="@(!GameEngine.CanPassTurn())">
                        Passar a Vez
                    </button>
                </div>
            }
        </main>
    </div>

    <footer class="board-footer">
        <button type="button" class="btn btn-outline-danger btn-lg" @onclick="EndGame">
            Encerrar Jogo
        </button>
    </footer>
    </div>
}

@code {
    private bool isDrawing;
    private bool showRules;
    private bool hostVoiceEnabled = true;
    private bool hostReadQuestions = true;
    private bool gameEndAnnounced;
    private bool endFxPlayed;
    private bool timerWarningAnnounced;
    private bool drawPulse;
    private bool cardDrawnPop;
    private bool cardRevealFlash;
    private readonly HashSet<Guid> scoreBumpIds = new();
    private readonly Dictionary<Guid, (int Points, int Chocolates)> lastScores = new();
    private IJSObjectReference? fxModule;
    private string selectedTargetIdString = string.Empty;
    private string donorPlayerIdString = string.Empty;
    private string recipientPlayerIdString = string.Empty;
    private int answerSecondsRemaining = -1;
    private int _answerTimerGeneration;
    private CancellationTokenSource? _answerTimerCts;
    private CancellationTokenSource? _gameClockCts;

    private bool ShowAnswerTimer =>
        answerSecondsRemaining >= 0
        && GameEngine.CurrentCard is not null
        && GameEngineService.IsQuestionCard(GameEngine.CurrentCard)
        && GameEngine.CardRevealed
        && !GameEngine.ShowAnswer;

    private bool ShowGradingPanel => GameEngine.CurrentQuestionNeedsGrading();

    private bool ShowGradingResult =>
        GameEngine.EffectApplied
        && GameEngine.LastQuestionWasCorrect.HasValue
        && GameEngine.CurrentCard is not null
        && GameEngineService.IsQuestionCard(GameEngine.CurrentCard);

    private IEnumerable<Player> OtherPlayers =>
        GameEngine.CurrentPlayer is null
            ? []
            : GameEngine.GetOtherPlayers(GameEngine.CurrentPlayer.Id);

    private bool NeedsTargetSelection => GameEngine.CurrentCardNeedsTargetSelection();

    private bool NeedsDonationTargets => GameEngine.CurrentCardNeedsDonationTargets();

    private bool ShowSocialChallenge => GameEngine.SocialChallengePending;

    private bool CanApplyTarget =>
        Guid.TryParse(selectedTargetIdString, out _);

    private bool CanApplyDonation =>
        Guid.TryParse(donorPlayerIdString, out var donorId)
        && Guid.TryParse(recipientPlayerIdString, out var recipientId)
        && donorId != recipientId;

    protected override async Task OnInitializedAsync()
    {
        GameEngine.StateChanged += OnStateChanged;
        SyncHostVoiceSettings();

        if (!GameEngine.IsGameStarted)
        {
            Navigation.NavigateTo("/");
            return;
        }

        GameEngine.RefreshEndConditions();
        _ = StartGameClockAsync();
        SnapshotScores();
        await LoadFxModuleAsync();
        await HostVoice.AnnounceWelcomeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (GameEngine.IsGameEnded && !endFxPlayed && fxModule is not null)
        {
            endFxPlayed = true;
            try
            {
                await fxModule.InvokeVoidAsync("burstConfetti");
            }
            catch
            {
                // Efeito visual opcional.
            }
        }
    }

    private async Task LoadFxModuleAsync()
    {
        try
        {
            fxModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/boardFx.js");
        }
        catch
        {
            fxModule = null;
        }
    }

    private void SnapshotScores()
    {
        lastScores.Clear();
        foreach (var player in GameEngine.Players)
            lastScores[player.Id] = (player.Points, player.Chocolates);
    }

    private async Task TriggerScoreBumpFxAsync()
    {
        scoreBumpIds.Clear();
        foreach (var player in GameEngine.Players)
        {
            if (!lastScores.TryGetValue(player.Id, out var previous))
                continue;

            if (player.Points > previous.Points || player.Chocolates > previous.Chocolates)
                scoreBumpIds.Add(player.Id);

            lastScores[player.Id] = (player.Points, player.Chocolates);
        }

        if (scoreBumpIds.Count == 0)
            return;

        StateHasChanged();
        await Task.Delay(900);
        scoreBumpIds.Clear();
        StateHasChanged();
    }

    private async Task PlaySmallConfettiAsync()
    {
        if (fxModule is null)
            return;

        try
        {
            await fxModule.InvokeVoidAsync("burstConfettiSmall");
        }
        catch
        {
            // Efeito visual opcional.
        }
    }

    private static string GetFunTitle(Player player, int rankIndex) =>
        rankIndex switch
        {
            0 => GameHostScripts.ChampionFunTitle(player.Name),
            1 => GameHostScripts.SecondPlaceFunTitle(player.Name),
            2 => GameHostScripts.ThirdPlaceFunTitle(player.Name),
            _ => string.Empty
        };

    private static bool IsStealAction(string? actionCode)
    {
        if (string.IsNullOrWhiteSpace(actionCode))
            return false;

        var code = actionCode.Split(':', StringSplitOptions.RemoveEmptyEntries)[0];
        return code is "StealAllChocolates" or "StealChocolate";
    }

    private void SyncHostVoiceSettings()
    {
        HostVoice.IsEnabled = hostVoiceEnabled;
        HostVoice.ReadQuestions = hostReadQuestions;
        if (!hostVoiceEnabled || (!hostReadQuestions && GameEngine.CurrentCard is not null && GameEngineService.IsQuestionCard(GameEngine.CurrentCard) && GameEngine.CardRevealed))
        {
            _ = HostVoice.StopAsync();
        }
    }

    private async Task RepeatHostSpeech() =>
        await HostVoice.RepeatCurrentAsync(GameEngine);

    private void OnStateChanged() =>
        InvokeAsync(async () =>
        {
            await SyncAnswerTimerAsync();
            await TryAnnounceGameEndAsync();
            StateHasChanged();
        });

    private async Task TryAnnounceGameEndAsync()
    {
        if (!GameEngine.IsGameEnded || gameEndAnnounced)
            return;

        gameEndAnnounced = true;
        await HostVoice.AnnounceGameEndAsync(GameEngine);
    }

    private async Task DrawCard()
    {
        if (GameEngine.CurrentCard is not null)
            return;

        isDrawing = true;
        drawPulse = true;
        timerWarningAnnounced = false;
        StateHasChanged();

        try
        {
            await Task.Delay(120);
            GameEngine.DrawCard();
            cardDrawnPop = true;
            selectedTargetIdString = string.Empty;
            donorPlayerIdString = string.Empty;
            recipientPlayerIdString = string.Empty;
            await HostVoice.AnnounceAfterDrawAsync(GameEngine);
            await Task.Delay(650);
        }
        catch (InvalidOperationException)
        {
            GameEngine.CheckTimeLimit();
        }
        finally
        {
            drawPulse = false;
            cardDrawnPop = false;
            isDrawing = false;
            StateHasChanged();
        }
    }

    private async Task RevealCard()
    {
        GameEngine.RevealCard();
        cardRevealFlash = true;
        StateHasChanged();
        _ = ClearRevealFlashAsync();

        if (GameEngine.CurrentCard is not null
            && GameEngineService.IsQuestionCard(GameEngine.CurrentCard)
            && GameEngine.CurrentPlayer is not null)
        {
            await HostVoice.AnnounceQuestionRevealedAsync(
                GameEngine.CurrentCard,
                GameEngine.CurrentPlayer.Name);
        }
    }

    private async Task ClearRevealFlashAsync()
    {
        await Task.Delay(700);
        cardRevealFlash = false;
        await InvokeAsync(StateHasChanged);
    }

    private void RevealAnswer()
    {
        StopAnswerTimer();
        GameEngine.RevealAnswer();
    }

    private async Task RecordAnswer(bool correct)
    {
        var playerName = GameEngine.CurrentPlayer?.Name ?? "Jogador";
        var card = GameEngine.CurrentCard;
        GameEngine.RecordQuestionResult(correct);
        await HostVoice.AnnounceQuestionResultAsync(playerName, correct, card);

        if (correct)
        {
            await HostVoice.AnnouncePlacarAfterCorrectAsync(GameEngine, playerName);
            await PlaySmallConfettiAsync();
        }
        else
        {
            await HostVoice.AnnouncePlacarAfterWrongAsync(GameEngine, playerName);
        }

        await TriggerScoreBumpFxAsync();
    }

    private async Task SelectOption(char option)
    {
        StopAnswerTimer();
        var playerName = GameEngine.CurrentPlayer?.Name ?? "Jogador";
        var card = GameEngine.CurrentCard;
        GameEngine.SelectMultipleChoiceOption(option);
        var correct = GameEngine.LastQuestionWasCorrect == true;
        await HostVoice.AnnounceQuestionResultAsync(playerName, correct, card);

        if (correct)
        {
            await HostVoice.AnnouncePlacarAfterCorrectAsync(GameEngine, playerName);
            await PlaySmallConfettiAsync();
        }
        else
        {
            await HostVoice.AnnouncePlacarAfterWrongAsync(GameEngine, playerName);
        }

        await TriggerScoreBumpFxAsync();
    }

    private void EndGame()
    {
        StopAnswerTimer();
        GameEngine.EndGame();
    }

    private async Task GoHome()
    {
        StopGameClock();
        await HostVoice.StopAsync();
        GameEngine.ResetGame();
        Navigation.NavigateTo("/");
    }

    private async Task ApplyTargetEffect()
    {
        if (!CanApplyTarget)
            return;

        if (Guid.TryParse(selectedTargetIdString, out var targetId))
        {
            var targetName = GameEngine.Players.FirstOrDefault(p => p.Id == targetId)?.Name;
            var actorName = GameEngine.CurrentPlayer?.Name ?? "Jogador";
            var actionCode = GameEngine.CurrentCard?.ActionCode;
            GameEngine.ApplyActionToTarget(targetId);
            await HostVoice.AnnounceActionEffectAsync(GameEngine, targetName);

            if (IsStealAction(actionCode) && !string.IsNullOrEmpty(targetName))
                await HostVoice.AnnouncePlacarAfterStealAsync(GameEngine, actorName, targetName);

            await TriggerScoreBumpFxAsync();
        }
    }

    private async Task ApplyDonationEffect()
    {
        if (!CanApplyDonation)
            return;

        if (Guid.TryParse(donorPlayerIdString, out var donorId)
            && Guid.TryParse(recipientPlayerIdString, out var recipientId))
        {
            var donorName = GameEngine.Players.FirstOrDefault(p => p.Id == donorId)?.Name;
            var recipientName = GameEngine.Players.FirstOrDefault(p => p.Id == recipientId)?.Name;
            GameEngine.ApplyActionToTargets(donorId, recipientId);
            await HostVoice.AnnounceActionEffectAsync(GameEngine, donorName, recipientName);
            await TriggerScoreBumpFxAsync();
        }
    }

    private async Task ConfirmSocialChallenge()
    {
        var playerName = GameEngine.CurrentPlayer?.Name ?? "Jogador";
        GameEngine.ConfirmSocialChallenge();
        await HostVoice.AnnounceSocialChallengeDoneAsync(playerName);
    }

    private void ToggleRules() => showRules = !showRules;

    private void PassTurn()
    {
        StopAnswerTimer();
        GameEngine.PassTurn();
        selectedTargetIdString = string.Empty;
        donorPlayerIdString = string.Empty;
        recipientPlayerIdString = string.Empty;
    }

    private string GetEndGameMessage() => GameEngine.EndReason switch
    {
        GameEndReason.TimeExpired when GameEngine.SessionDurationLimit.HasValue =>
            "O tempo combinado da partida chegou ao fim.",
        GameEndReason.TimeExpired =>
            $"A partida atingiu o limite de {GameRules.MaxGameDurationHours} horas.",
        GameEndReason.QuestionsExhausted =>
            "As cartas de pergunta acabaram.",
        GameEndReason.Manual => "Partida encerrada pelo grupo.",
        _ => "Partida finalizada."
    };

    private async Task SyncAnswerTimerAsync()
    {
        var shouldRun = GameEngine.CurrentCard is not null
            && GameEngineService.IsQuestionCard(GameEngine.CurrentCard)
            && GameEngine.CardRevealed
            && !GameEngine.ShowAnswer
            && !GameEngine.IsGameEnded;

        if (!shouldRun)
        {
            StopAnswerTimer();
            return;
        }

        if (_answerTimerCts is not null)
            return;

        await StartAnswerTimerAsync();
    }

    private async Task StartAnswerTimerAsync()
    {
        StopAnswerTimer();

        var generation = ++_answerTimerGeneration;
        answerSecondsRemaining = GameEngineService.AnswerRevealTimeoutSeconds;
        _answerTimerCts = new CancellationTokenSource();
        var token = _answerTimerCts.Token;

        try
        {
            while (answerSecondsRemaining > 0 && !token.IsCancellationRequested && generation == _answerTimerGeneration)
            {
                await Task.Delay(1000, token);
                if (token.IsCancellationRequested || generation != _answerTimerGeneration)
                    return;

                answerSecondsRemaining--;
                if (answerSecondsRemaining == 10
                    && !timerWarningAnnounced
                    && GameEngine.CurrentPlayer is not null)
                {
                    timerWarningAnnounced = true;
                    await HostVoice.AnnounceTimerWarningAsync(
                        GameEngine.CurrentPlayer.Name,
                        answerSecondsRemaining);
                }

                await InvokeAsync(StateHasChanged);
            }

            if (token.IsCancellationRequested || generation != _answerTimerGeneration)
                return;

            if (GameEngine.CurrentCard is not null
                && GameEngineService.IsQuestionCard(GameEngine.CurrentCard)
                && GameEngine.CardRevealed
                && !GameEngine.ShowAnswer)
            {
                GameEngine.RevealAnswer();
                answerSecondsRemaining = -1;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task StartGameClockAsync()
    {
        StopGameClock();
        _gameClockCts = new CancellationTokenSource();
        var token = _gameClockCts.Token;

        try
        {
            while (!token.IsCancellationRequested && GameEngine.IsGameStarted && !GameEngine.IsGameEnded)
            {
                GameEngine.RefreshEndConditions();
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000, token);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void StopAnswerTimer()
    {
        _answerTimerGeneration++;
        _answerTimerCts?.Cancel();
        _answerTimerCts?.Dispose();
        _answerTimerCts = null;
        answerSecondsRemaining = -1;
    }

    private void StopGameClock()
    {
        _gameClockCts?.Cancel();
        _gameClockCts?.Dispose();
        _gameClockCts = null;
    }

    private string FormatGameClock()
    {
        var remaining = GameEngine.TimeRemaining;
        if (remaining.HasValue)
            return $"restam {FormatDuration(remaining.Value)}";

        return FormatDuration(GameEngine.Elapsed);
    }

    private static string FormatDuration(TimeSpan span)
    {
        if (span.TotalHours >= 1)
            return $"{(int)span.TotalHours}:{span.Minutes:D2}:{span.Seconds:D2}";

        return $"{span.Minutes}:{span.Seconds:D2}";
    }

    private static string FormatTimer(int seconds) =>
        $"{seconds / 60}:{seconds % 60:D2}";

    private static string GetCardTypeClass(Card card) => card.Type switch
    {
        CardType.Question => "card-question",
        CardType.Reward => "card-reward",
        CardType.Penalty => "card-penalty",
        _ => "card-action"
    };

    private static string GetCardTypeLabel(Card card) => card.Type switch
    {
        CardType.Question => "Pergunta",
        CardType.Reward => "Recompensa",
        CardType.Penalty => "Penalidade",
        _ => "Ação"
    };

    public void Dispose()
    {
        StopAnswerTimer();
        StopGameClock();
        GameEngine.StateChanged -= OnStateChanged;
        _ = HostVoice.StopAsync();
        if (fxModule is not null)
            _ = fxModule.DisposeAsync();
    }
}
